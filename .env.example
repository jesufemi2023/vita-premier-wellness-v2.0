# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Analytics
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Supabase Configuration
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Business Configuration
VITE_COMPANY_NAME="SD GHT HEALTH CARE"
VITE_COMPANY_SUBTITLE="NIGERIA LTD"
VITE_CONTACT_PHONE="+234 (0) 123 456 789"
VITE_DEFAULT_DISTRIBUTOR_ID="SD-GHT-MEMBER-001"
VITE_LOGO_URL="https://your-logo-url.com/logo.png"

# Hero Images (Carousel)
# You can use a single comma-separated list for unlimited images
VITE_HERO_IMAGES="https://picsum.photos/seed/healthcare-supplement-1/1920/1080, https://picsum.photos/seed/healthcare-supplement-2/1920/1080"
# OR use numbered variables (VITE_HERO_IMAGE_1 to VITE_HERO_IMAGE_20)
VITE_HERO_IMAGE_1="https://picsum.photos/seed/healthcare-supplement-1/1920/1080"
VITE_HERO_IMAGE_2="https://picsum.photos/seed/healthcare-supplement-2/1920/1080"

# WhatsApp Configuration
VITE_WHATSAPP_NUMBER="2347060734773"
VITE_WHATSAPP_DEFAULT_MESSAGE="Hello SD GHT Health Care, I would like to make an inquiry."

# AI Configuration
AI_SYSTEM_INSTRUCTION="You are a professional health consultant for SD GHT Health Care. Recommend GHT products based on symptoms."
GEMINI_API_KEYS="key1,key2,key3" # Optional: Comma-separated list of keys for rotation to bypass free tier limits
AI_CACHE_TTL_HOURS="24" # How long to cache AI responses
AI_MAX_RETRIES="3" # How many times to retry on rate limit
AI_RETRY_DELAY_MS="1000" # Base delay for exponential backoff

# Cloudinary Configuration (Multiple Accounts Support)
# Format: CLOUD_NAME:API_KEY:API_SECRET,CLOUD_NAME:API_KEY:API_SECRET
# Example: ght-a:key1:secret1,ght-b:key2:secret2
CLOUDINARY_ACCOUNTS=
# Fallback for single account (standard)
CLOUDINARY_URL=

# Notification Configuration (Gmail)
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-16-digit-app-password"
NOTIFICATION_EMAIL_TO="your-email@gmail.com"

# Notification Configuration (Telegram)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="7115203133"
